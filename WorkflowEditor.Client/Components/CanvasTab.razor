@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@implements IDisposable
@using Blazor.Diagrams
@using Blazor.Diagrams.Components
@using Blazor.Diagrams.Core.Anchors
@using Fluxor
@using WorkflowEditor.Client.Diagram.Nodes
@using WorkflowEditor.Client.Store.Editor
@using WorkflowEditor.Core.Models
@using Blazor.Diagrams.Core.Models.Base
@using Microsoft.AspNetCore.Components
@using WorkflowEditor.Client.Components.Nodes
@using WorkflowEditor.Core.Models.Steps

<style>
    /* Глобальные стили для портов, обходящие CSS-изоляцию */
    .port {
        width: 16px;
        height: 16px;
        background-color: #3267ff;
        border: 2px solid #1e1e1e;
        border-radius: 50%;
        position: absolute;
        cursor: crosshair;
        z-index: 10;
        transition: transform 0.1s ease-in-out;
    }
    .port:hover {
        background-color: #ff4081;
        transform: scale(1.3);
    }
    .port.left { top: 50%; left: -8px; transform: translateY(-50%); }
    .port.right { top: 50%; right: -8px; transform: translateY(-50%); }
    .port.top { left: 50%; top: -8px; transform: translateX(-50%); }
    .port.bottom { left: 50%; bottom: -8px; transform: translateX(-50%); }
</style>

<div class="canvas-wrapper default-theme" style="width: 100%; height: 100%;">
    <CascadingValue Value="Diagram">
        <DiagramCanvas></DiagramCanvas>
    </CascadingValue>
</div>

@code {
    [Inject] private IState<EditorState> State { get; set; } = null!;
    [Inject] private IDispatcher Dispatcher { get; set; } = null!;
    [Parameter] public string WorkflowId { get; set; } = string.Empty;
    [Parameter] public EventCallback<SelectableModel?> OnObjectSelected { get; set; }

    private BlazorDiagram Diagram { get; set; } = new BlazorDiagram();
    
    // Флаг для защиты от рекурсивных вызовов
    private bool _isSyncing = false; 

    protected override void OnInitialized()
    {
        base.OnInitialized();
        // Используем именованный делегат, чтобы отписка сработала корректно
        State.StateChanged += OnStateChanged;
        
        Diagram.RegisterComponent<SubflowNodeModel, SubflowNodeWidget>();
        Diagram.RegisterComponent<BaseNodeModel, BaseNodeWidget>();
        
        Diagram.PointerUp += OnDiagramPointerUp;
        Diagram.Links.Added += OnLinkAdded;
        Diagram.Links.Removed += OnLinkRemoved;
        
        SyncStateToDiagram();
    }

    private void OnStateChanged(object? sender, EventArgs args) => SyncStateToDiagram();

    private void SyncStateToDiagram()
    {
        if (!State.Value.OpenDocuments.TryGetValue(WorkflowId, out var document)) return;
        if (_isSyncing) return;

        _isSyncing = true;
        InvokeAsync(() => 
        {
            // 1. Синхронизация узлов
            var nodesToRemove = Diagram.Nodes.OfType<WorkflowNodeModel>()
                .Where(n => document.Steps.All(s => s.Id != n.StepId)).ToList();
            Diagram.Nodes.Remove(nodesToRemove);

            foreach (var step in document.Steps)
            {
                var existingNode = Diagram.Nodes.OfType<WorkflowNodeModel>().FirstOrDefault(n => n.StepId == step.Id);
                if (existingNode == null)
                {
                    if (step is SubflowStep subflow) existingNode = new SubflowNodeModel(subflow);
                    else if (step is BaseStep task) existingNode = new BaseNodeModel(task);
                    
                    if (existingNode != null) Diagram.Nodes.Add(existingNode);
                }

                if (existingNode != null)
                {
                    // ПРИНУДИТЕЛЬНАЯ СИНХРОНИЗАЦИЯ КООРДИНАТ
                    existingNode.SetPosition(step.Position.X, step.Position.Y);
                    
                }
            }

            // 2. Синхронизация линков
            var linksToRemove = Diagram.Links
                .Where(l => l.Target is SinglePortAnchor && !document.Links.Any(dl => MatchLink(l, dl))).ToList();
            Diagram.Links.Remove(linksToRemove);

            foreach (var link in document.Links)
            {
                if (Diagram.Links.Any(l => MatchLink(l, link))) continue;

                var sourceNode = Diagram.Nodes.OfType<WorkflowNodeModel>().FirstOrDefault(n => n.StepId == link.SourceNodeId);
                var targetNode = Diagram.Nodes.OfType<WorkflowNodeModel>().FirstOrDefault(n => n.StepId == link.TargetNodeId);

                if (sourceNode != null && targetNode != null)
                {
                    var sourcePort = sourceNode.Ports.FirstOrDefault(p => p.Alignment.ToString() == link.SourcePortId);
                    var targetPort = targetNode.Ports.FirstOrDefault(p => p.Alignment.ToString() == link.TargetPortId);

                    if (sourcePort != null && targetPort != null)
                    {
                        var diagramLink = new Blazor.Diagrams.Core.Models.LinkModel(sourcePort, targetPort);
                        Diagram.Links.Add(diagramLink);
                    }
                }
            }

            StateHasChanged();
            _isSyncing = false;
        });
    }

    // Вспомогательный метод для матчинга линков движка с контрактами Fluxor
    private bool MatchLink(Blazor.Diagrams.Core.Models.Base.BaseLinkModel diagramLink, WorkflowLink stateLink)
    {
        var sourcePort = (diagramLink.Source as SinglePortAnchor)?.Port;
        var targetPort = (diagramLink.Target as SinglePortAnchor)?.Port;
        
        if (sourcePort?.Parent is WorkflowNodeModel sNode && targetPort?.Parent is WorkflowNodeModel tNode)
        {
            return sNode.StepId == stateLink.SourceNodeId && 
                   sourcePort.Alignment.ToString() == stateLink.SourcePortId &&
                   tNode.StepId == stateLink.TargetNodeId &&
                   targetPort.Alignment.ToString() == stateLink.TargetPortId;
        }
        return false;
    }

    private void OnDiagramPointerUp(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        if (e.Button is 0) // Левая кнопка мыши
        {
            if (_isSyncing) return;
        
            foreach (var node in Diagram.Nodes)
            {
                if (node is WorkflowNodeModel workflowNode && node.Selected)
                {
                    if (node.Position.X == 0 && node.Position.Y == 0) continue;

                    var newPos = new CanvasPosition(node.Position.X, node.Position.Y);
                    Dispatcher.Dispatch(new MoveStepAction(WorkflowId, workflowNode.StepId, newPos));
                }
            }
        }
        else if (e.Button is 2) // Правая кнопка мыши
        {
            OnObjectSelected.InvokeAsync(model as SelectableModel);
        }
    }

    private void OnLinkAdded(Blazor.Diagrams.Core.Models.Base.BaseLinkModel link)
    {
        link.TargetChanged += (l, _, newTarget) => 
        {
            if (_isSyncing) return;
            
            var sourcePort = (l.Source as SinglePortAnchor)?.Port;
            var targetPort = (newTarget as SinglePortAnchor)?.Port;

            if (sourcePort?.Parent is WorkflowNodeModel sourceNode && targetPort?.Parent is WorkflowNodeModel targetNode)
            {
                var workflowLink = new WorkflowLink
                {
                    Id = Guid.NewGuid().ToString(),
                    SourceNodeId = sourceNode.StepId,
                    SourcePortId = sourcePort.Alignment.ToString(), 
                    TargetNodeId = targetNode.StepId,
                    TargetPortId = targetPort.Alignment.ToString()
                };

                Dispatcher.Dispatch(new AddLinkAction(WorkflowId, workflowLink));
            }
        };
    }

    private void OnLinkRemoved(Blazor.Diagrams.Core.Models.Base.BaseLinkModel link)
    {
        if (_isSyncing || !(link.Target is SinglePortAnchor)) return; 
        
        if (State.Value.OpenDocuments.TryGetValue(WorkflowId, out var document))
        {
            var stateLink = document.Links.FirstOrDefault(dl => MatchLink(link, dl));
            if (stateLink != null)
            {
                Dispatcher.Dispatch(new RemoveLinkAction(WorkflowId, stateLink.Id));
            }
        }
    }
    
    public void Dispose()
    {
        State.StateChanged -= OnStateChanged;
        Diagram.PointerUp -= OnDiagramPointerUp;
        Diagram.Links.Added -= OnLinkAdded;
        Diagram.Links.Removed -= OnLinkRemoved;
    }
}