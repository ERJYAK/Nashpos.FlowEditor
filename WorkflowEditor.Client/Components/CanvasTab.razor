@inherits FluxorComponent
@implements IDisposable

<style>
    .port {
        width: 16px; height: 16px;
        background-color: #3267ff;
        border: 2px solid #1e1e1e;
        border-radius: 50%;
        position: absolute;
        cursor: crosshair;
        z-index: 10;
        transition: transform 0.1s ease-in-out;
    }
    .port:hover { background-color: #ff4081; transform: scale(1.3); }
    .port.left   { top: 50%; left:  -8px; transform: translateY(-50%); }
    .port.right  { top: 50%; right: -8px; transform: translateY(-50%); }
    .port.top    { left: 50%; top:    -8px; transform: translateX(-50%); }
    .port.bottom { left: 50%; bottom: -8px; transform: translateX(-50%); }
    .selected-node { border: 3px solid #3267ff !important; }
</style>

<div class="canvas-wrapper default-theme" style="width: 100%; height: 100%;">
    <CascadingValue Value="Diagram">
        <DiagramCanvas></DiagramCanvas>
    </CascadingValue>
</div>

@if (_isBoxSelecting)
{
    var left = Math.Min(_boxStartScreenX, _boxCurrentScreenX);
    var top = Math.Min(_boxStartScreenY, _boxCurrentScreenY);
    var width = Math.Abs(_boxCurrentScreenX - _boxStartScreenX);
    var height = Math.Abs(_boxCurrentScreenY - _boxStartScreenY);
    <div style="position: fixed;
                left: @(left.ToString(System.Globalization.CultureInfo.InvariantCulture))px;
                top: @(top.ToString(System.Globalization.CultureInfo.InvariantCulture))px;
                width: @(width.ToString(System.Globalization.CultureInfo.InvariantCulture))px;
                height: @(height.ToString(System.Globalization.CultureInfo.InvariantCulture))px;
                background: rgba(50, 103, 255, 0.15);
                border: 1px dashed #3267ff;
                pointer-events: none;
                z-index: 1000;"></div>
}

@code {
    [Inject] private IState<EditorState> State { get; set; } = null!;
    [Inject] private IDispatcher Dispatcher { get; set; } = null!;
    [Inject] private MudBlazor.ISnackbar Snackbar { get; set; } = null!;
    [Parameter] public string Name { get; set; } = string.Empty;
    [Parameter] public EventCallback<IReadOnlyList<SelectableModel>> OnSelectionChanged { get; set; }
    [Parameter] public EventCallback<(IReadOnlyList<SelectableModel> Selection, double CanvasX, double CanvasY)> OnContextMenuRequested { get; set; }

    private BlazorDiagram Diagram { get; set; } = new BlazorDiagram(
        new BlazorDiagramOptions { AllowPanning = false });

    private bool _isSyncing;
    private bool _isInitialSync = true;

    private bool _isBoxSelecting;
    private double _boxStartScreenX, _boxStartScreenY;
    private double _boxCurrentScreenX, _boxCurrentScreenY;
    private double _boxStartCanvasX, _boxStartCanvasY;
    private bool _boxAdditive;

    private double _lastClientX;
    private double _lastClientY;

    private bool _isMmbPanning;
    private double _mmbPanLastX, _mmbPanLastY;

    // Подписки на TargetChanged каждого линка — снимать при удалении.
    private readonly Dictionary<Blazor.Diagrams.Core.Models.Base.BaseLinkModel,
        Action<Blazor.Diagrams.Core.Models.Base.BaseLinkModel,
               Blazor.Diagrams.Core.Anchors.Anchor,
               Blazor.Diagrams.Core.Anchors.Anchor>> _linkTargetChangedHandlers = new();

    private const int BoxSelectFrameThrottleMs = 16;
    private long _boxSelectLastFrameTicks;

    private List<SelectableModel>? _pendingSelection;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        State.StateChanged += OnStateChanged;

        Diagram.RegisterComponent<SubflowNodeModel, SubflowNodeWidget>();
        Diagram.RegisterComponent<BaseNodeModel, BaseNodeWidget>();
        Diagram.RegisterComponent<JsScriptNodeModel, JsScriptNodeWidget>();

        Diagram.PointerDown += OnDiagramPointerDown;
        Diagram.PointerMove += OnDiagramPointerMove;
        Diagram.PointerUp += OnDiagramPointerUp;
        Diagram.KeyDown += OnDiagramKeyDown;
        Diagram.SelectionChanged += OnDiagramSelectionChanged;
        Diagram.Links.Added += OnLinkAdded;
        Diagram.Links.Removed += OnLinkRemoved;
        Diagram.Nodes.Removed += OnNodeRemoved;

        SyncStateToDiagram();
    }

    private void OnStateChanged(object? sender, EventArgs args) => SyncStateToDiagram();

    // Страховка против stale-узлов: даже если @key уберут — sync обязательно вызовется
    // на каждое изменение Name, без ожидания State.StateChanged.
    private string? _lastSyncedName;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        if (Name != _lastSyncedName)
        {
            _lastSyncedName = Name;
            SyncStateToDiagram();
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingSelection is { Count: > 0 } sel)
        {
            _pendingSelection = null;
            Diagram.UnselectAll();
            foreach (var m in sel) Diagram.SelectModel(m, unselectOthers: false);
            StateHasChanged();
        }
        return base.OnAfterRenderAsync(firstRender);
    }

    private void SyncStateToDiagram()
    {
        if (!State.Value.OpenDocuments.TryGetValue(Name, out var editor)) return;
        if (_isSyncing) return;

        _isSyncing = true;
        InvokeAsync(() =>
        {
            try
            {
                var newlyAdded = new List<SelectableModel>();

                // --- Узлы ---
                var stepIds = editor.Document.Steps.Select(s => s.Id).ToHashSet();
                var nodeById = Diagram.Nodes.OfType<WorkflowNodeModel>().ToDictionary(n => n.StepId);

                var nodesToRemove = nodeById
                    .Where(kv => !stepIds.Contains(kv.Key))
                    .Select(kv => (NodeModel)kv.Value)
                    .ToList();
                Diagram.Nodes.Remove(nodesToRemove);

                foreach (var step in editor.Document.Steps)
                {
                    var position = editor.NodePositions.GetValueOrDefault(step.Id, new CanvasPosition(0, 0));

                    if (!nodeById.TryGetValue(step.Id, out var existing))
                    {
                        WorkflowNodeModel? node = step switch
                        {
                            SubflowStep s => new SubflowNodeModel(s, position),
                            BaseStep b when b.StepKind == JsScriptNodeModel.ConstStepKind
                                => new JsScriptNodeModel(b, position),
                            BaseStep b    => new BaseNodeModel(b, position),
                            _ => null
                        };
                        if (node is not null)
                        {
                            Diagram.Nodes.Add(node);
                            nodeById[step.Id] = node;
                            newlyAdded.Add(node);
                        }
                    }
                    else
                    {
                        if (existing.Title != step.Description)
                        {
                            existing.Title = step.Description;
                            existing.Refresh();
                        }
                        existing.MarkSynced(position);
                    }
                }

                // --- Связи ---
                var stateLinkIds = editor.Links.Keys.ToHashSet();
                var diagramLinkPairs = Diagram.Links
                    .Select(l => (Diagram: l, State: TryMatchToState(l, editor)))
                    .ToList();

                var linksToRemove = diagramLinkPairs
                    .Where(p => p.State is null)
                    .Select(p => p.Diagram)
                    .ToList();
                Diagram.Links.Remove(linksToRemove);

                var existingStateLinkIds = diagramLinkPairs
                    .Where(p => p.State is not null)
                    .Select(p => p.State!.Id)
                    .ToHashSet();

                foreach (var (id, link) in editor.Links)
                {
                    if (existingStateLinkIds.Contains(id)) continue;
                    if (!nodeById.TryGetValue(link.SourceStepId, out var sourceNode)) continue;
                    if (!nodeById.TryGetValue(link.TargetStepId, out var targetNode)) continue;

                    var sourcePort = sourceNode.GetPort(PortAlignment.Bottom) ?? sourceNode.Ports.FirstOrDefault();
                    var targetPort = targetNode.GetPort(PortAlignment.Top) ?? targetNode.Ports.FirstOrDefault();
                    if (sourcePort is null || targetPort is null) continue;

                    var diagramLink = new LinkModel(sourcePort, targetPort)
                    {
                        TargetMarker = LinkMarker.Arrow
                    };
                    Diagram.Links.Add(diagramLink);
                }

                if (!_isInitialSync && newlyAdded.Count > 0)
                {
                    _pendingSelection = newlyAdded;
                }
                _isInitialSync = false;

                StateHasChanged();
            }
            finally
            {
                _isSyncing = false;
            }
        });
    }

    private static EditorLink? TryMatchToState(
        Blazor.Diagrams.Core.Models.Base.BaseLinkModel diagramLink,
        EditorDocument editor)
    {
        var sourcePort = (diagramLink.Source as SinglePortAnchor)?.Port;
        var targetPort = (diagramLink.Target as SinglePortAnchor)?.Port;
        if (sourcePort?.Parent is not WorkflowNodeModel src) return null;
        if (targetPort?.Parent is not WorkflowNodeModel tgt) return null;

        return editor.Links.Values.FirstOrDefault(l =>
            l.SourceStepId == src.StepId && l.TargetStepId == tgt.StepId);
    }

    private IReadOnlyList<SelectableModel> CurrentSelection() =>
        Diagram.GetSelectedModels().OfType<SelectableModel>().ToList();

    private void OnDiagramSelectionChanged(SelectableModel _) =>
        OnSelectionChanged.InvokeAsync(CurrentSelection());

    private void OnDiagramPointerDown(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        if (e.Button == 1)
        {
            _isMmbPanning = true;
            _mmbPanLastX = e.ClientX;
            _mmbPanLastY = e.ClientY;
            return;
        }

        if (e.Button != 0 || model is not null) return;

        var canvasPoint = Diagram.GetRelativeMousePoint(e.ClientX, e.ClientY);
        _isBoxSelecting = true;
        _boxStartScreenX = e.ClientX;
        _boxStartScreenY = e.ClientY;
        _boxCurrentScreenX = e.ClientX;
        _boxCurrentScreenY = e.ClientY;
        _boxStartCanvasX = canvasPoint.X;
        _boxStartCanvasY = canvasPoint.Y;
        _boxAdditive = e.CtrlKey || e.ShiftKey;
        StateHasChanged();
    }

    private void OnDiagramPointerMove(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        _lastClientX = e.ClientX;
        _lastClientY = e.ClientY;

        if (_isMmbPanning)
        {
            Diagram.UpdatePan(e.ClientX - _mmbPanLastX, e.ClientY - _mmbPanLastY);
            _mmbPanLastX = e.ClientX;
            _mmbPanLastY = e.ClientY;
            return;
        }

        if (!_isBoxSelecting) return;

        _boxCurrentScreenX = e.ClientX;
        _boxCurrentScreenY = e.ClientY;

        var nowTicks = Environment.TickCount64;
        if (nowTicks - _boxSelectLastFrameTicks < BoxSelectFrameThrottleMs) return;
        _boxSelectLastFrameTicks = nowTicks;
        StateHasChanged();
    }

    private void OnDiagramPointerUp(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        if (e.Button is 1)
        {
            _isMmbPanning = false;
            return;
        }

        if (e.Button is 0)
        {
            if (_isBoxSelecting)
            {
                FinishBoxSelection(e);
                return;
            }

            // Сохраняем UI-only позиции узлов в EditorDocument.NodePositions
            if (!State.Value.OpenDocuments.ContainsKey(Name)) return;
            foreach (var node in Diagram.Nodes.OfType<WorkflowNodeModel>())
            {
                var current = new CanvasPosition(node.Position.X, node.Position.Y);
                if (current == node.LastSyncedPosition) continue;

                Dispatcher.Dispatch(new MoveStepAction(Name, node.StepId, current));
                node.MarkSynced(current);
            }
        }
        else if (e.Button is 2)
        {
            var selection = CurrentSelection();
            if (model is SelectableModel target && !selection.Contains(target))
            {
                selection = new List<SelectableModel> { target };
            }
            var canvasPoint = Diagram.GetRelativeMousePoint(e.ClientX, e.ClientY);
            OnContextMenuRequested.InvokeAsync((selection, canvasPoint.X, canvasPoint.Y));
        }
    }

    private void OnDiagramKeyDown(Blazor.Diagrams.Core.Events.KeyboardEventArgs e)
    {
        if (State.Value.EditingStepId is not null) return;
        if (!e.CtrlKey) return;

        if ((e.Key is "z" or "Z" || e.Code == "KeyZ") && !e.ShiftKey)
        {
            if (State.Value.CanUndo(Name)) Dispatcher.Dispatch(new UndoAction(Name));
        }
        else if (e.Key is "y" or "Y" || e.Code == "KeyY"
                 || ((e.Key is "z" or "Z" || e.Code == "KeyZ") && e.ShiftKey))
        {
            if (State.Value.CanRedo(Name)) Dispatcher.Dispatch(new RedoAction(Name));
        }
        else if (e.Key is "c" or "C" || e.Code == "KeyC")
        {
            var stepIds = CurrentSelection().OfType<WorkflowNodeModel>().Select(n => n.StepId).ToList();
            if (stepIds.Count > 0)
                Dispatcher.Dispatch(new CopySelectionAction(Name, stepIds));
        }
        else if (e.Key is "v" or "V" || e.Code == "KeyV")
        {
            if (State.Value.Clipboard is null) return;
            var pt = Diagram.GetRelativeMousePoint(_lastClientX, _lastClientY);
            Dispatcher.Dispatch(new PasteClipboardAction(Name, pt.X, pt.Y));
        }
    }

    private void FinishBoxSelection(Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        var endCanvas = Diagram.GetRelativeMousePoint(e.ClientX, e.ClientY);
        var minX = Math.Min(_boxStartCanvasX, endCanvas.X);
        var minY = Math.Min(_boxStartCanvasY, endCanvas.Y);
        var maxX = Math.Max(_boxStartCanvasX, endCanvas.X);
        var maxY = Math.Max(_boxStartCanvasY, endCanvas.Y);

        _isBoxSelecting = false;

        if (Math.Abs(endCanvas.X - _boxStartCanvasX) < 4 && Math.Abs(endCanvas.Y - _boxStartCanvasY) < 4)
        {
            StateHasChanged();
            return;
        }

        if (!_boxAdditive) Diagram.UnselectAll();

        foreach (var node in Diagram.Nodes)
        {
            if (node.Size is null) continue;
            var pos = node.Position;
            var nodeRight = pos.X + node.Size.Width;
            var nodeBottom = pos.Y + node.Size.Height;
            if (pos.X < maxX && nodeRight > minX && pos.Y < maxY && nodeBottom > minY)
                Diagram.SelectModel(node, unselectOthers: false);
        }

        foreach (var link in Diagram.Links)
        {
            var sp = (link.Source as SinglePortAnchor)?.Port;
            var tp = (link.Target as SinglePortAnchor)?.Port;
            if (sp?.Parent is not WorkflowNodeModel sn) continue;
            if (tp?.Parent is not WorkflowNodeModel tn) continue;
            if (sn.Size is null || tn.Size is null) continue;

            var midX = (sn.Position.X + sn.Size.Width / 2 + tn.Position.X + tn.Size.Width / 2) / 2;
            var midY = (sn.Position.Y + sn.Size.Height / 2 + tn.Position.Y + tn.Size.Height / 2) / 2;
            if (midX >= minX && midX <= maxX && midY >= minY && midY <= maxY)
                Diagram.SelectModel(link, unselectOthers: false);
        }

        StateHasChanged();
    }

    private void OnLinkAdded(Blazor.Diagrams.Core.Models.Base.BaseLinkModel link)
    {
        link.TargetMarker = LinkMarker.Arrow;

        Action<Blazor.Diagrams.Core.Models.Base.BaseLinkModel,
               Blazor.Diagrams.Core.Anchors.Anchor,
               Blazor.Diagrams.Core.Anchors.Anchor> handler = (l, _, newTarget) =>
        {
            if (_isSyncing) return;
            var sp = (l.Source as SinglePortAnchor)?.Port;
            var tp = (newTarget as SinglePortAnchor)?.Port;
            if (sp?.Parent is not WorkflowNodeModel src) return;
            if (tp?.Parent is not WorkflowNodeModel tgt) return;

            // Линейная цепочка: запрещаем самоссылку и >1 исходящую/входящую.
            if (src.StepId == tgt.StepId)
            {
                Snackbar.Add("Шаг не может ссылаться на самого себя", MudBlazor.Severity.Warning);
                Diagram.Links.Remove(l);
                return;
            }
            if (State.Value.OpenDocuments.TryGetValue(Name, out var editor))
            {
                if (editor.Links.Values.Any(existing => existing.TargetStepId == tgt.StepId))
                {
                    Snackbar.Add("У шага уже есть входящая связь", MudBlazor.Severity.Warning);
                    Diagram.Links.Remove(l);
                    return;
                }
                if (editor.Links.Values.Any(existing => existing.SourceStepId == src.StepId))
                {
                    Snackbar.Add("У шага уже есть исходящая связь", MudBlazor.Severity.Warning);
                    Diagram.Links.Remove(l);
                    return;
                }
            }

            var editorLink = new EditorLink
            {
                Id = Guid.NewGuid().ToString(),
                SourceStepId = src.StepId,
                TargetStepId = tgt.StepId
            };
            Dispatcher.Dispatch(new AddLinkAction(Name, editorLink));
        };

        link.TargetChanged += handler;
        _linkTargetChangedHandlers[link] = handler;
    }

    private void OnLinkRemoved(Blazor.Diagrams.Core.Models.Base.BaseLinkModel link)
    {
        if (_linkTargetChangedHandlers.Remove(link, out var handler))
            link.TargetChanged -= handler;

        if (_isSyncing || link.Target is not SinglePortAnchor) return;

        if (State.Value.OpenDocuments.TryGetValue(Name, out var editor))
        {
            var stateLink = TryMatchToState(link, editor);
            if (stateLink is not null)
                Dispatcher.Dispatch(new RemoveLinksAction(Name, [stateLink.Id]));
        }
    }

    private void OnNodeRemoved(NodeModel node)
    {
        if (_isSyncing) return;
        if (node is WorkflowNodeModel wNode)
            Dispatcher.Dispatch(new RemoveStepsAction(Name, [wNode.StepId]));
    }

    public (double X, double Y)? GetViewportCenter()
    {
        if (Diagram.Container is null) return null;
        var cx = Diagram.Container.Left + Diagram.Container.Width / 2;
        var cy = Diagram.Container.Top + Diagram.Container.Height / 2;
        var pt = Diagram.GetRelativeMousePoint(cx, cy);
        return (pt.X, pt.Y);
    }

    public void Dispose()
    {
        State.StateChanged -= OnStateChanged;
        Diagram.PointerDown -= OnDiagramPointerDown;
        Diagram.PointerMove -= OnDiagramPointerMove;
        Diagram.PointerUp -= OnDiagramPointerUp;
        Diagram.KeyDown -= OnDiagramKeyDown;
        Diagram.SelectionChanged -= OnDiagramSelectionChanged;
        Diagram.Links.Added -= OnLinkAdded;
        Diagram.Links.Removed -= OnLinkRemoved;
        Diagram.Nodes.Removed -= OnNodeRemoved;

        foreach (var (link, handler) in _linkTargetChangedHandlers)
            link.TargetChanged -= handler;
        _linkTargetChangedHandlers.Clear();
    }
}
