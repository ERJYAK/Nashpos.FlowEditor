@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@using Blazor.Diagrams
@using Blazor.Diagrams.Components
@using Fluxor
@using WorkflowEditor.Client.Diagram.Nodes
@using WorkflowEditor.Client.Store.Editor
@using WorkflowEditor.Core.Models
@using Blazor.Diagrams.Core.Models.Base

<div class="canvas-wrapper" style="width: 100%; height: 100%;">
    <CascadingValue Value="Diagram">
        <DiagramCanvas></DiagramCanvas>
    </CascadingValue>
</div>

@code {
    [Inject] private IState<EditorState> State { get; set; } = null!;
    [Inject] private IDispatcher Dispatcher { get; set; } = null!;

    [Parameter] public string WorkflowId { get; set; } = string.Empty;

    private BlazorDiagram Diagram { get; set; } = new BlazorDiagram();
    private bool _isSyncing = false;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        // Подписываемся на события движка (Снизу-Вверх: UI -> Fluxor)
        Diagram.PointerUp += OnDiagramPointerUp;
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        // Синхронизируем данные при смене активной вкладки/стейта (Сверху-Вниз: Fluxor -> UI)
        SyncStateToDiagram();
    }

    private void SyncStateToDiagram()
    {
        if (!State.Value.OpenDocuments.TryGetValue(WorkflowId, out var document)) return;

        _isSyncing = true;
        Diagram.Nodes.Clear();

        // Проходим по иммутабельному списку из Core и создаем визуальные узлы
        foreach (var step in document.Steps)
        {
            // Здесь потребуется фабрика, которая по типу step (TimerStep, SubflowStep) 
            // будет создавать правильный WorkflowNodeModel. 
            // Пока для примера создаем базовый узел.
            // var node = NodeFactory.Create(step); 
            // Diagram.Nodes.Add(node);
        }
        _isSyncing = false;
    }

    private void OnDiagramPointerUp(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        // Проверяем все узлы на предмет выделения и изменения координат.
        // Если мы перетаскивали конкретный узел, его новые координаты нужно зафиксировать во Fluxor.
        foreach (var node in Diagram.Nodes)
        {
            if (node is WorkflowNodeModel workflowNode && node.Selected)
            {
                var newPos = new CanvasPosition(node.Position.X, node.Position.Y);
                Dispatcher.Dispatch(new MoveStepAction(WorkflowId, workflowNode.StepId, newPos));
            }
        }
    }
}