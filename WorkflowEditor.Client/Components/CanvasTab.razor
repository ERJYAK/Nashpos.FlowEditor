@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@implements IDisposable
@using Blazor.Diagrams
@using Blazor.Diagrams.Components
@using Blazor.Diagrams.Core.Anchors
@using Blazor.Diagrams.Core.Models
@using Fluxor
@using WorkflowEditor.Client.Diagram.Nodes
@using WorkflowEditor.Client.Store.Editor
@using WorkflowEditor.Core.Models
@using Blazor.Diagrams.Core.Models.Base
@using Blazor.Diagrams.Options
@using Microsoft.AspNetCore.Components
@using WorkflowEditor.Client.Components.Nodes
@using WorkflowEditor.Core.Models.Steps

<style>
    /* Глобальные стили для портов, обходящие CSS-изоляцию */
    .port {
        width: 16px;
        height: 16px;
        background-color: #3267ff;
        border: 2px solid #1e1e1e;
        border-radius: 50%;
        position: absolute;
        cursor: crosshair;
        z-index: 10;
        transition: transform 0.1s ease-in-out;
    }
    .port:hover {
        background-color: #ff4081;
        transform: scale(1.3);
    }
    .port.left { top: 50%; left: -8px; transform: translateY(-50%); }
    .port.right { top: 50%; right: -8px; transform: translateY(-50%); }
    .port.top { left: 50%; top: -8px; transform: translateX(-50%); }
    .port.bottom { left: 50%; bottom: -8px; transform: translateX(-50%); }
    
    .selected-node {
        border: 3px solid #3267ff !important;
    }
</style>

<div class="canvas-wrapper default-theme" style="width: 100%; height: 100%;">
    <CascadingValue Value="Diagram">
        <DiagramCanvas></DiagramCanvas>
    </CascadingValue>
</div>

@if (_isBoxSelecting)
{
    var left = Math.Min(_boxStartScreenX, _boxCurrentScreenX);
    var top = Math.Min(_boxStartScreenY, _boxCurrentScreenY);
    var width = Math.Abs(_boxCurrentScreenX - _boxStartScreenX);
    var height = Math.Abs(_boxCurrentScreenY - _boxStartScreenY);
    <div style="position: fixed;
                left: @(left.ToString(System.Globalization.CultureInfo.InvariantCulture))px;
                top: @(top.ToString(System.Globalization.CultureInfo.InvariantCulture))px;
                width: @(width.ToString(System.Globalization.CultureInfo.InvariantCulture))px;
                height: @(height.ToString(System.Globalization.CultureInfo.InvariantCulture))px;
                background: rgba(50, 103, 255, 0.15);
                border: 1px dashed #3267ff;
                pointer-events: none;
                z-index: 1000;"></div>
}

@code {
    [Inject] private IState<EditorState> State { get; set; } = null!;
    [Inject] private IDispatcher Dispatcher { get; set; } = null!;
    [Parameter] public string WorkflowId { get; set; } = string.Empty;
    [Parameter] public EventCallback<IReadOnlyList<SelectableModel>> OnSelectionChanged { get; set; }
    [Parameter] public EventCallback<(IReadOnlyList<SelectableModel> Selection, double CanvasX, double CanvasY)> OnContextMenuRequested { get; set; }

    private BlazorDiagram Diagram { get; set; } = new BlazorDiagram(
        new BlazorDiagramOptions { AllowPanning = false });

    // Флаг для защиты от рекурсивных вызовов
    private bool _isSyncing = false;
    private bool _isInitialSync = true;

    // Состояние рамки выделения (rubber-band)
    private bool _isBoxSelecting;
    private double _boxStartScreenX, _boxStartScreenY;
    private double _boxCurrentScreenX, _boxCurrentScreenY;
    private double _boxStartCanvasX, _boxStartCanvasY;
    private bool _boxAdditive;
    
    // Последние координаты пользовательского курсора
    private double _lastClientX;
    private double _lastClientY;

    // Состояние панорамирования средней кнопкой мыши
    private bool _isMmbPanning;
    private double _mmbPanLastX, _mmbPanLastY;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        // Используем именованный делегат, чтобы отписка сработала корректно
        State.StateChanged += OnStateChanged;
        
        Diagram.RegisterComponent<SubflowNodeModel, SubflowNodeWidget>();
        Diagram.RegisterComponent<BaseNodeModel, BaseNodeWidget>();
        
        Diagram.PointerDown += OnDiagramPointerDown;
        Diagram.PointerMove += OnDiagramPointerMove;
        Diagram.PointerUp += OnDiagramPointerUp;
        Diagram.KeyDown += OnDiagramKeyDown;
        Diagram.SelectionChanged += OnDiagramSelectionChanged;
        Diagram.Links.Added += OnLinkAdded;
        Diagram.Links.Removed += OnLinkRemoved;
        Diagram.Nodes.Removed += OnNodeRemoved;
        
        SyncStateToDiagram();
    }

    private void OnStateChanged(object? sender, EventArgs args) => SyncStateToDiagram();

    private void SyncStateToDiagram()
    {
        if (!State.Value.OpenDocuments.TryGetValue(WorkflowId, out var document)) return;
        if (_isSyncing) return;

        _isSyncing = true;
        InvokeAsync(() => 
        {
            // Список для сбора свежесозданных визуальных элементов (узлов и связей)
            var newlyAddedModels = new List<SelectableModel>();
            
            // 1. Синхронизация узлов
            var nodesToRemove = Diagram.Nodes.OfType<WorkflowNodeModel>()
                .Where(n => document.Steps.All(s => s.Id != n.StepId)).ToList();
            Diagram.Nodes.Remove(nodesToRemove);

            foreach (var step in document.Steps)
            {
                var existingNode = Diagram.Nodes.OfType<WorkflowNodeModel>().FirstOrDefault(n => n.StepId == step.Id);
                if (existingNode == null)
                {
                    WorkflowNodeModel? newNode = step switch
                    {
                        SubflowStep subflow => new SubflowNodeModel(subflow),
                        BaseStep task       => new BaseNodeModel(task),
                        _                   => null
                    };
                    if (newNode != null)
                    {
                        Diagram.Nodes.Add(newNode);
                        newlyAddedModels.Add(newNode); // Собираем добавленный узел
                    }
                }
                else if (existingNode.Title != step.Name)
                {
                    existingNode.Title = step.Name;
                    existingNode.Refresh();
                }
                // Существующие узлы: позиция управляется холстом, не перезаписывается из состояния
            }

            // 2. Синхронизация линков
            var linksToRemove = Diagram.Links
                .Where(l => l.Target is SinglePortAnchor && !document.Links.Any(dl => MatchLink(l, dl))).ToList();
            Diagram.Links.Remove(linksToRemove);

            foreach (var link in document.Links)
            {
                if (Diagram.Links.Any(l => MatchLink(l, link))) continue;

                var sourceNode = Diagram.Nodes.OfType<WorkflowNodeModel>().FirstOrDefault(n => n.StepId == link.SourceNodeId);
                var targetNode = Diagram.Nodes.OfType<WorkflowNodeModel>().FirstOrDefault(n => n.StepId == link.TargetNodeId);

                if (sourceNode != null && targetNode != null)
                {
                    var sourcePort = sourceNode.Ports.FirstOrDefault(p => p.Alignment.ToString() == link.SourcePortId);
                    var targetPort = targetNode.Ports.FirstOrDefault(p => p.Alignment.ToString() == link.TargetPortId);

                    if (sourcePort != null && targetPort != null)
                    {
                        var diagramLink = new Blazor.Diagrams.Core.Models.LinkModel(sourcePort, targetPort);
                        Diagram.Links.Add(diagramLink);
                    }
                }
            }

            // --- НОВАЯ ЛОГИКА ВЫДЕЛЕНИЯ ---
            if (!_isInitialSync && newlyAddedModels.Count > 0)
            {
                // Отвязываем логику выделения от текущего синхронного потока событий.
                // Это решает 2 проблемы:
                // 1. Дает Blazor время физически отрендерить компоненты узлов в DOM.
                // 2. Ждет завершения всплытия событий браузера (например, MouseUp от контекстного меню), 
                //    которое иначе заставит глобальный обработчик движка сбросить наше выделение.
                _ = Task.Run(async () => 
                {
                    await Task.Delay(50); // 50мс достаточно для завершения цикла рендеринга и очистки Call Stack
                
                    await InvokeAsync(() => 
                    {
                        Diagram.UnselectAll(); // Снимаем выделение со старых объектов
                        foreach (var model in newlyAddedModels)
                        {
                            Diagram.SelectModel(model, unselectOthers: false); // Выделяем только вставленные
                        }
                        StateHasChanged(); // Принудительно обновляем UI для отображения синих рамок
                    });
                });
            }
            
            _isInitialSync = false; // Первая синхронизация пройдена
            
            StateHasChanged();
            _isSyncing = false;
        });
    }

    // Вспомогательный метод для матчинга линков движка с контрактами Fluxor
    private bool MatchLink(Blazor.Diagrams.Core.Models.Base.BaseLinkModel diagramLink, WorkflowLink stateLink)
    {
        var sourcePort = (diagramLink.Source as SinglePortAnchor)?.Port;
        var targetPort = (diagramLink.Target as SinglePortAnchor)?.Port;
        
        if (sourcePort?.Parent is WorkflowNodeModel sNode && targetPort?.Parent is WorkflowNodeModel tNode)
        {
            return sNode.StepId == stateLink.SourceNodeId && 
                   sourcePort.Alignment.ToString() == stateLink.SourcePortId &&
                   tNode.StepId == stateLink.TargetNodeId &&
                   targetPort.Alignment.ToString() == stateLink.TargetPortId;
        }
        return false;
    }

    private IReadOnlyList<SelectableModel> CurrentSelection()
        => Diagram.GetSelectedModels().OfType<SelectableModel>().ToList();

    private void OnDiagramSelectionChanged(SelectableModel _)
    {
        // Срабатывает на каждое изменение выделения; передаём родителю весь актуальный набор.
        OnSelectionChanged.InvokeAsync(CurrentSelection());
    }

    private void OnDiagramPointerDown(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        if (e.Button == 1) // СКМ — панорамирование
        {
            _isMmbPanning = true;
            _mmbPanLastX = e.ClientX;
            _mmbPanLastY = e.ClientY;
            return;
        }

        // Запускаем рамку выделения только при ЛКМ по пустому холсту
        if (e.Button != 0 || model != null) return;

        var canvasPoint = Diagram.GetRelativeMousePoint(e.ClientX, e.ClientY);
        _isBoxSelecting = true;
        _boxStartScreenX = e.ClientX;
        _boxStartScreenY = e.ClientY;
        _boxCurrentScreenX = e.ClientX;
        _boxCurrentScreenY = e.ClientY;
        _boxStartCanvasX = canvasPoint.X;
        _boxStartCanvasY = canvasPoint.Y;
        _boxAdditive = e.CtrlKey || e.ShiftKey;
        StateHasChanged();
    }

    private void OnDiagramPointerMove(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        // Сохраняем последние координаты для Ctrl+V
        _lastClientX = e.ClientX;
        _lastClientY = e.ClientY;
        
        if (_isMmbPanning)
        {
            Diagram.UpdatePan(e.ClientX - _mmbPanLastX, e.ClientY - _mmbPanLastY);
            _mmbPanLastX = e.ClientX;
            _mmbPanLastY = e.ClientY;
            return;
        }

        if (!_isBoxSelecting) return;

        _boxCurrentScreenX = e.ClientX;
        _boxCurrentScreenY = e.ClientY;
        StateHasChanged();
    }
    
    private void OnDiagramPointerUp(Model? model, Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        if (e.Button is 1) // СКМ — завершение панорамирования
        {
            _isMmbPanning = false;
            return;
        }

        if (e.Button is 0) // Левая кнопка мыши
        {
            if (_isBoxSelecting)
            {
                FinishBoxSelection(e);
                return;
            }

            if (!State.Value.OpenDocuments.TryGetValue(WorkflowId, out var document)) return;

            // Собираем все сдвиги узлов и фиксируем одним экшеном
            var moves = new List<(string StepId, CanvasPosition NewPosition)>();
            foreach (var node in Diagram.Nodes.OfType<WorkflowNodeModel>())
            {
                if (node.Position.X == 0 && node.Position.Y == 0) continue;
                var step = document.Steps.FirstOrDefault(s => s.Id == node.StepId);
                if (step == null) continue;

                if (step.Position.X == node.Position.X && step.Position.Y == node.Position.Y) continue;

                moves.Add((node.StepId, new CanvasPosition(node.Position.X, node.Position.Y)));
            }

            if (moves.Count > 0)
                Dispatcher.Dispatch(new MoveStepsAction(WorkflowId, moves));
        }
        else if (e.Button is 2) // Правая кнопка мыши
        {
            var selection = CurrentSelection();
            if (model is SelectableModel target && !selection.Contains(target))
            {
                selection = new List<SelectableModel> { target };
            }
            var canvasPoint = Diagram.GetRelativeMousePoint(e.ClientX, e.ClientY);
            OnContextMenuRequested.InvokeAsync((selection, canvasPoint.X, canvasPoint.Y));
        }
    }
    
    private void OnDiagramKeyDown(Blazor.Diagrams.Core.Events.KeyboardEventArgs e)
    {
        // Если сейчас редактируется имя узла, игнорируем нажатия клавиш на холсте
        if (State.Value.EditingStepId != null) return;

        // Проверяем нажатие Ctrl
        if (e.CtrlKey)
        {
            // Логика копирования (Ctrl+C)
            if (e.Key == "c" || e.Key == "C" || e.Code == "KeyC")
            {
                var selection = CurrentSelection();
                // Проверяем, есть ли что копировать (узлы или линки)
                if (selection.OfType<WorkflowNodeModel>().Any() || selection.OfType<LinkModel>().Any())
                {
                    Dispatcher.Dispatch(new CopySelectionAction(selection));
                }
            }
            // Логика вставки (Ctrl+V)
            else if (e.Key == "v" || e.Key == "V" || e.Code == "KeyV")
            {
                if (State.Value.Clipboard != null)
                {
                    // Переводим экранные координаты курсора мыши в координаты холста (с учетом зума и панорамирования)
                    var canvasPoint = Diagram.GetRelativeMousePoint(_lastClientX, _lastClientY);
                    Dispatcher.Dispatch(new PasteClipboardAction(canvasPoint.X, canvasPoint.Y));
                }
            }
        }
    }
    
    private void FinishBoxSelection(Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        var endCanvas = Diagram.GetRelativeMousePoint(e.ClientX, e.ClientY);
        var minX = Math.Min(_boxStartCanvasX, endCanvas.X);
        var minY = Math.Min(_boxStartCanvasY, endCanvas.Y);
        var maxX = Math.Max(_boxStartCanvasX, endCanvas.X);
        var maxY = Math.Max(_boxStartCanvasY, endCanvas.Y);

        _isBoxSelecting = false;

        // Если пользователь по сути просто кликнул — рамка слишком маленькая, рассматриваем как обычный клик по холсту
        if (Math.Abs(endCanvas.X - _boxStartCanvasX) < 4 && Math.Abs(endCanvas.Y - _boxStartCanvasY) < 4)
        {
            StateHasChanged();
            return;
        }

        if (!_boxAdditive)
        {
            Diagram.UnselectAll();
        }

        foreach (var node in Diagram.Nodes)
        {
            var size = node.Size;
            if (size == null) continue; // Узел ещё не отрисован — пропускаем

            var pos = node.Position;
            var nodeRight = pos.X + size.Width;
            var nodeBottom = pos.Y + size.Height;

            var intersects = pos.X < maxX && nodeRight > minX && pos.Y < maxY && nodeBottom > minY;
            if (intersects)
            {
                Diagram.SelectModel(node, unselectOthers: false);
            }
        }

        // Линки тоже могут попадать в рамку: считаем «попавшим», если центр линии источник→цель внутри рамки
        foreach (var link in Diagram.Links)
        {
            var sourcePort = (link.Source as SinglePortAnchor)?.Port;
            var targetPort = (link.Target as SinglePortAnchor)?.Port;
            if (sourcePort?.Parent is not WorkflowNodeModel sourceNode) continue;
            if (targetPort?.Parent is not WorkflowNodeModel targetNode) continue;
            if (sourceNode.Size == null || targetNode.Size == null) continue;

            var sx = sourceNode.Position.X + sourceNode.Size.Width / 2;
            var sy = sourceNode.Position.Y + sourceNode.Size.Height / 2;
            var tx = targetNode.Position.X + targetNode.Size.Width / 2;
            var ty = targetNode.Position.Y + targetNode.Size.Height / 2;
            var midX = (sx + tx) / 2;
            var midY = (sy + ty) / 2;

            if (midX >= minX && midX <= maxX && midY >= minY && midY <= maxY)
            {
                Diagram.SelectModel(link, unselectOthers: false);
            }
        }

        StateHasChanged();
    }

    private void OnLinkAdded(Blazor.Diagrams.Core.Models.Base.BaseLinkModel link)
    {
        link.TargetChanged += (l, _, newTarget) => 
        {
            if (_isSyncing) return;
            
            var sourcePort = (l.Source as SinglePortAnchor)?.Port;
            var targetPort = (newTarget as SinglePortAnchor)?.Port;

            if (sourcePort?.Parent is WorkflowNodeModel sourceNode && targetPort?.Parent is WorkflowNodeModel targetNode)
            {
                var workflowLink = new WorkflowLink
                {
                    Id = Guid.NewGuid().ToString(),
                    SourceNodeId = sourceNode.StepId,
                    SourcePortId = sourcePort.Alignment.ToString(), 
                    TargetNodeId = targetNode.StepId,
                    TargetPortId = targetPort.Alignment.ToString()
                };

                Dispatcher.Dispatch(new AddLinkAction(WorkflowId, workflowLink));
            }
        };
    }

    private void OnLinkRemoved(Blazor.Diagrams.Core.Models.Base.BaseLinkModel link)
    {
        if (_isSyncing || !(link.Target is SinglePortAnchor)) return; 
        
        if (State.Value.OpenDocuments.TryGetValue(WorkflowId, out var document))
        {
            var stateLink = document.Links.FirstOrDefault(dl => MatchLink(link, dl));
            if (stateLink != null)
            {
                Dispatcher.Dispatch(new RemoveLinkAction(WorkflowId, stateLink.Id));
            }
        }
    }
    
    private void OnNodeRemoved(NodeModel node)
    {
        // Защита от зацикливания: игнорируем удаление, если оно вызвано синхронизацией стейта
        if (_isSyncing) return;
    
        if (node is WorkflowNodeModel wNode)
        {
            // Отправляем сигнал во Fluxor для удаления из стейта
            Dispatcher.Dispatch(new RemoveStepAction(WorkflowId, wNode.StepId));
        }
    }
    
    public (double X, double Y)? GetViewportCenter()
    {
        if (Diagram.Container == null) return null;
        var cx = Diagram.Container.Left + Diagram.Container.Width / 2;
        var cy = Diagram.Container.Top + Diagram.Container.Height / 2;
        var pt = Diagram.GetRelativeMousePoint(cx, cy);
        return (pt.X, pt.Y);
    }

    public void Dispose()
    {
        State.StateChanged -= OnStateChanged;
        Diagram.PointerDown -= OnDiagramPointerDown;
        Diagram.PointerMove -= OnDiagramPointerMove;
        Diagram.PointerUp -= OnDiagramPointerUp;
        Diagram.KeyDown -= OnDiagramKeyDown;
        Diagram.SelectionChanged -= OnDiagramSelectionChanged;
        Diagram.Links.Added -= OnLinkAdded;
        Diagram.Links.Removed -= OnLinkRemoved;
        Diagram.Nodes.Removed -= OnNodeRemoved;
    }
}