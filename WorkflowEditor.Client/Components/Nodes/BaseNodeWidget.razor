@inherits FluxorComponent
@* Базовый узел: показываем `StepKind` (тип реализации) и `Description`.
   Полноценное редактирование выйдет на этапе E (через PropertiesPanel). *@

<MudPaper Elevation="4"
          Class="@(Node.Selected ? "pa-3 selected-node" : "pa-3")"
          Style="min-width: 220px; cursor: pointer; position: relative; overflow: visible;">
    <MudStack Spacing="0">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Success" Size="Size.Small" />
            <MudText Typo="Typo.subtitle2">@(string.IsNullOrEmpty(Node.StepKind) ? "—" : Node.StepKind)</MudText>
        </MudStack>
        <MudText Typo="Typo.caption" Color="Color.Default">@Description</MudText>
    </MudStack>

    @foreach (var port in Node.Ports)
    {
        <PortRenderer Port="port" />
    }
</MudPaper>

@code {
    [Parameter] public BaseNodeModel Node { get; set; } = null!;
    [Inject] private IState<EditorState> State { get; set; } = null!;

    private string Description
    {
        get
        {
            var name = State.Value.ActiveDocumentName;
            if (name is null || !State.Value.OpenDocuments.TryGetValue(name, out var editor))
                return Node.Title ?? string.Empty;

            var step = editor.Document.Steps.FirstOrDefault(s => s.Id == Node.StepId);
            return step?.Description ?? Node.Title ?? string.Empty;
        }
    }
}
