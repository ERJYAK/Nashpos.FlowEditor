@inherits FluxorComponent
@* SubflowName/Description — из state по Node.StepId. Шаги subflow рендерятся всегда:
   приоритет — данные из OpenDocuments[name] (если subflow открыт во вкладке, свежее
   всего), fallback — SubflowCache (после фонового fetch'а). *@

<div @ondblclick="OpenSubflow" @ondblclick:stopPropagation="true">
<MudPaper Elevation="4"
          Class="@CardClass"
          Style="min-width: 260px; max-width: 360px; cursor: pointer; position: relative; overflow: visible;">
    <MudStack Spacing="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Lan" Color="Color.Primary" Size="Size.Small" />
            <MudText Typo="Typo.subtitle2" Style="flex-grow: 1;">@(string.IsNullOrEmpty(SubflowName) ? "—" : SubflowName)</MudText>
            <span @ondblclick:stopPropagation="true">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Size="Size.Small"
                               Color="Color.Default"
                               OnClick="OpenEdit"
                               title="Редактировать имя/описание" />
            </span>
        </MudStack>

        @if (!string.IsNullOrEmpty(Description))
        {
            <MudText Typo="Typo.caption">@Description</MudText>
        }

        <MudDivider Class="my-1" />

        @if (string.IsNullOrEmpty(SubflowName))
        {
            <MudText Typo="Typo.caption" Color="Color.Default">Имя подпроцесса не задано</MudText>
        }
        else if (CachedSubflow is { } cached)
        {
            @if (cached.Steps.Count == 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Default">Подпроцесс пуст</MudText>
            }
            else
            {
                <MudList T="object" Dense="true" Gutters="false">
                    @* Индекс объявлен ВНУТРИ for-loop scope — иначе все RenderFragment'ы
                       MudListItem захватили бы одну общую переменную и показали бы один номер. *@
                    @for (var i = 0; i < cached.Steps.Count; i++)
                    {
                        var index = i + 1;
                        var step = cached.Steps[i];
                        var label = StepLabel(step);
                        <MudListItem T="object" Class="py-0">
                            <MudText Typo="Typo.caption">@index. @label</MudText>
                        </MudListItem>
                    }
                </MudList>
            }
        }
        else if (State.Value.LoadingSubflows.Contains(SubflowName))
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                <MudText Typo="Typo.caption">Загрузка…</MudText>
            </MudStack>
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Default">
                Двойной клик — открыть подпроцесс
            </MudText>
        }
    </MudStack>

    @foreach (var port in Node.Ports)
    {
        <PortRenderer Port="port" />
    }
</MudPaper>
</div>

@code {
    [Parameter] public SubflowNodeModel Node { get; set; } = null!;
    [Inject] private IState<EditorState> State { get; set; } = null!;
    [Inject] private IDispatcher Dispatcher { get; set; } = null!;
    [Inject] private IDialogService Dialogs { get; set; } = null!;

    private string? SubflowName => CurrentStep<SubflowStep>()?.SubflowName;
    private string Description => CurrentStep<WorkflowStep>()?.Description ?? string.Empty;

    // Свежее всего: если subflow открыт как вкладка — берём напрямую из OpenDocuments;
    // иначе — последний результат фонового fetch'а из SubflowCache.
    private WorkflowDocument? CachedSubflow
    {
        get
        {
            var name = SubflowName;
            if (string.IsNullOrEmpty(name)) return null;
            if (State.Value.OpenDocuments.TryGetValue(name, out var open))
                return open.Document;
            return State.Value.SubflowCache.TryGetValue(name, out var cached) ? cached : null;
        }
    }

    private string CardClass
    {
        get
        {
            var classes = new List<string> { "pa-3" };
            if (Node.Selected) classes.Add("selected-node");
            var docName = State.Value.ActiveDocumentName;
            if (docName is not null && State.Value.InvalidStepsFor(docName).Contains(Node.StepId))
                classes.Add("invalid-node");
            return string.Join(' ', classes);
        }
    }

    private T? CurrentStep<T>() where T : WorkflowStep
    {
        var name = State.Value.ActiveDocumentName;
        if (name is null || !State.Value.OpenDocuments.TryGetValue(name, out var editor)) return null;
        return editor.Document.Steps.OfType<T>().FirstOrDefault(s => s.Id == Node.StepId);
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        TryFetch();
    }

    // Идемпотентен: безопасно вызывать на каждый pere-render. Не дёргает API во время
    // batch-импорта (импортируемые файлы могут заполнить кэш сами — нет смысла спекулировать).
    private void TryFetch()
    {
        var name = SubflowName;
        if (string.IsNullOrEmpty(name)) return;
        if (State.Value.PendingImports > 0) return;
        if (State.Value.OpenDocuments.ContainsKey(name)) return;
        if (State.Value.SubflowCache.ContainsKey(name)) return;
        if (State.Value.LoadingSubflows.Contains(name)) return;

        Dispatcher.Dispatch(new LoadSubflowAction(name));
    }

    private void OpenSubflow()
    {
        if (string.IsNullOrEmpty(SubflowName)) return;
        Dispatcher.Dispatch(new OpenSubflowAction(SubflowName));
    }

    private async Task OpenEdit()
    {
        var docName = State.Value.ActiveDocumentName;
        if (docName is null) return;
        var step = CurrentStep<WorkflowStep>();
        if (step is null) return;

        var parameters = new DialogParameters { { nameof(EditStepDialog.Step), step } };
        var dialog = await Dialogs.ShowAsync<EditStepDialog>("Редактирование подпроцесса", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not EditStepDialog.EditStepResult edit) return;

        if (step is SubflowStep s && s.SubflowName != edit.KindOrName)
            Dispatcher.Dispatch(new UpdateSubflowNameAction(docName, step.Id, edit.KindOrName));
        if (step.Description != edit.Description)
            Dispatcher.Dispatch(new UpdateStepDescriptionAction(docName, step.Id, edit.Description));
    }

    private static string StepLabel(WorkflowStep step)
    {
        var description = string.IsNullOrEmpty(step.Description) ? null : step.Description;
        var name = step switch
        {
            BaseStep b => b.StepKind,
            SubflowStep s => s.SubflowName,
            _ => string.Empty
        };
        return (description, name) switch
        {
            (null, "")  => "—",
            (null, _)   => name,
            (_, "")     => description!,
            _           => $"{name} — {description}"
        };
    }
}
