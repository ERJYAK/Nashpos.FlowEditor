@inherits LayoutComponentBase
@using MudBlazor

<style>
    /* Рантайм-инъекция стилей с правильным именем класса движка */
    .diagram-port {
        width: 16px !important;
        height: 16px !important;
        background-color: #3267ff !important;
        border: 2px solid #ffffff !important;
        border-radius: 50% !important;
        position: absolute !important;
        z-index: 100 !important;
        display: block !important;
        cursor: crosshair !important;
    }
    
    .diagram-port:hover {
        background-color: #ff4081 !important;
        transform: scale(1.3) !important;
    }
    
    /* Позиционирование относительно MudPaper */
    .diagram-port.left { left: -8px !important; top: 50% !important; transform: translateY(-50%) !important; }
    .diagram-port.right { right: -8px !important; top: 50% !important; transform: translateY(-50%) !important; }
    .diagram-port.top { top: -8px !important; left: 50% !important; transform: translateX(-50%) !important; }
    .diagram-port.bottom { bottom: -8px !important; left: 50% !important; transform: translateX(-50%) !important; }
</style>

<MudThemeProvider/>
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider /> 
<MudLayout>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark()
        {
            Primary = "#3267ff", // Синий как на твоих примерах
            Surface = "#1e1e1e",
            Background = "#121212",
            AppbarBackground = "#1a1a1a"
        }
    };
}