@inherits LayoutComponentBase
@implements IDisposable
@inject IActionSubscriber Subscriber
@inject ISnackbar Snackbar

<style>
    /* Рантайм-инъекция стилей с правильным именем класса движка */
    .diagram-port {
        width: 16px !important;
        height: 16px !important;
        background-color: #3267ff !important;
        border: 2px solid #ffffff !important;
        border-radius: 50% !important;
        position: absolute !important;
        z-index: 100 !important;
        display: block !important;
        cursor: crosshair !important;
    }

    .diagram-port:hover {
        background-color: #ff4081 !important;
        transform: scale(1.3) !important;
    }

    /* Позиционирование относительно MudPaper */
    .diagram-port.left { left: -8px !important; top: 50% !important; transform: translateY(-50%) !important; }
    .diagram-port.right { right: -8px !important; top: 50% !important; transform: translateY(-50%) !important; }
    .diagram-port.top { top: -8px !important; left: 50% !important; transform: translateX(-50%) !important; }
    .diagram-port.bottom { bottom: -8px !important; left: 50% !important; transform: translateX(-50%) !important; }
</style>

<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />
<MudLayout>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark()
        {
            Primary = "#3267ff",
            Surface = "#1e1e1e",
            Background = "#121212",
            AppbarBackground = "#1a1a1a"
        }
    };

    protected override void OnInitialized()
    {
        Subscriber.SubscribeToAction<LoadWorkflowFailedAction>(this,
            a => Snackbar.Add($"Не удалось загрузить процесс: {a.ErrorMessage}", Severity.Error));
        Subscriber.SubscribeToAction<SaveWorkflowFailedAction>(this,
            a => Snackbar.Add($"Не удалось сохранить процесс: {a.ErrorMessage}", Severity.Error));
        Subscriber.SubscribeToAction<SaveWorkflowSuccessAction>(this,
            _ => Snackbar.Add("Сохранено", Severity.Success));
        Subscriber.SubscribeToAction<ImportFileFailedAction>(this,
            a => Snackbar.Add($"Не удалось загрузить файл «{a.FileName}»: {a.ErrorMessage}", Severity.Error));
        Subscriber.SubscribeToAction<LoadSubflowFailedAction>(this,
            a => Snackbar.Add($"Подпроцесс «{a.Name}» не загружен: {a.ErrorMessage}", Severity.Warning));
    }

    public void Dispose() => Subscriber.UnsubscribeFromAllActions(this);
}
