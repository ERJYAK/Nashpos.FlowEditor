@using MudBlazor
@using Microsoft.AspNetCore.Components.Web
@using Blazor.Diagrams.Core.Models.Base
@using WorkflowEditor.Client.Store.Editor
@using Fluxor
@using WorkflowEditor.Client.Diagram.Nodes
@using Blazor.Diagrams.Core.Models

@inherits Fluxor.Blazor.Web.Components.FluxorComponent

@inject IState<EditorState> EditorState
@inject IDispatcher Dispatcher

@if (IsOpen)
{
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 9998;"
         @onclick="CloseMenu"
         @oncontextmenu="CloseMenu"
         @oncontextmenu:preventDefault="true">
    </div>

    <div style="position: fixed; top: @(Y)px; left: @(X)px; z-index: 9999;">
        <MudPaper Elevation="8" Class="py-1" Style="min-width: 160px;">
            <MudMenuItem OnClick="OnCopy" Disabled="@(!IsCopyable())">Копировать</MudMenuItem>
            <MudMenuItem OnClick="OnPaste" Disabled="@(!IsPastable())">Вставить</MudMenuItem>
            <MudMenuItem OnClick="OnEdit">Изменить</MudMenuItem>
            <MudMenuItem OnClick="OnDelete" Disabled="@(_selection.Count == 0)">Удалить</MudMenuItem>v
        </MudPaper>
    </div>
}

@code {
    public bool IsOpen { get; private set; }
    public double X { get; private set; }
    public double Y { get; private set; }
    private double _pasteCanvasX;
    private double _pasteCanvasY;
    private IReadOnlyList<SelectableModel> _selection = Array.Empty<SelectableModel>();

    public void Open(double screenX, double screenY, IReadOnlyList<SelectableModel> selection,
                     double canvasX, double canvasY)
    {
        X = screenX;
        Y = screenY;
        _pasteCanvasX = canvasX;
        _pasteCanvasY = canvasY;
        _selection = selection ?? Array.Empty<SelectableModel>();
        IsOpen = true;
        StateHasChanged();
    }

    public void CloseMenu()
    {
        IsOpen = false;
        _selection = Array.Empty<SelectableModel>();
        StateHasChanged();
    }

    private bool IsCopyable()
    {
        return _selection.OfType<WorkflowNodeModel>().Any() ||
               _selection.OfType<LinkModel>().Any();
    }

    private bool IsPastable()
    {
        return EditorState.Value.Clipboard != null;
    }

    private void OnCopy()
    {
        if (IsCopyable())
        {
            Dispatcher.Dispatch(new CopySelectionAction(_selection));
        }
        CloseMenu();
    }

    private void OnPaste()
    {
        if (IsPastable())
        {
            Dispatcher.Dispatch(new PasteClipboardAction(_pasteCanvasX, _pasteCanvasY));
        }
        CloseMenu();
    }

    private void OnEdit()
    {
        Console.WriteLine("[Контекстное меню] Выбрано: Изменить");
        CloseMenu();
    }

    private void OnDelete()
    {
        if (_selection.Count > 0)
        {
            Dispatcher.Dispatch(new DeleteSelectionAction(_selection));
        }
        CloseMenu();
    }
}