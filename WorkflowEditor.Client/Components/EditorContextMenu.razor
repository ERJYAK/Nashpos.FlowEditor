@using MudBlazor
@using Microsoft.AspNetCore.Components.Web
@using Blazor.Diagrams.Core.Models.Base
@using WorkflowEditor.Client.Store.Editor
@using Fluxor
@using WorkflowEditor.Client.Diagram.Nodes
@using WorkflowEditor.Client.Store.Editor

@inherits Fluxor.Blazor.Web.Components.FluxorComponent

@inject IState<EditorState> EditorState
@inject IDispatcher Dispatcher

@if (IsOpen)
{
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 9998;"
         @onclick="CloseMenu"
         @oncontextmenu="CloseMenu"
         @oncontextmenu:preventDefault="true">
    </div>

    <div style="position: fixed; top: @(Y)px; left: @(X)px; z-index: 9999;">
        <MudPaper Elevation="8" Class="py-1" Style="min-width: 160px;">
            <MudMenuItem OnClick="OnCopy" Disabled="@(!IsCopyable())">Копировать</MudMenuItem>
            <MudMenuItem OnClick="OnPaste" Disabled="@(!IsPastable())">Вставить</MudMenuItem>
            <MudMenuItem OnClick="OnEdit">Изменить</MudMenuItem>
            <MudMenuItem OnClick="OnDelete" Disabled="@(_selectedObject is null)">Удалить</MudMenuItem>
        </MudPaper>
    </div>
}

@code {
    public bool IsOpen { get; private set; }
    public double X { get; private set; }
    public double Y { get; private set; }
    private SelectableModel? _selectedObject;

    public void Open(double x, double y, SelectableModel? selectedObject = null)
    {
        X = x;
        Y = y;
        _selectedObject = selectedObject;
        IsOpen = true;
        StateHasChanged();
    }

    public void CloseMenu()
    {
        IsOpen = false;
        _selectedObject = null;
        StateHasChanged();
    }

    private bool IsCopyable()
    {
        return _selectedObject is WorkflowNodeModel;
    }

    private bool IsPastable()
    {
        return EditorState.Value.CopiedStep != null;
    }

    private void OnCopy()
    {
        if (IsCopyable())
        {
            Dispatcher.Dispatch(new CopySelectedItemAction(_selectedObject!));
        }
        CloseMenu();
    }

    private void OnPaste()
    {
        if (IsPastable())
        {
            Dispatcher.Dispatch(new PasteItemAction(X, Y));
        }
        CloseMenu();
    }

    private void OnEdit()
    {
        Console.WriteLine("[Контекстное меню] Выбрано: Изменить");
        CloseMenu();
    }

    private void OnDelete()
    {
        if (_selectedObject != null)
        {
            Dispatcher.Dispatch(new DeleteSelectedItemAction(_selectedObject));
        }
        CloseMenu();
    }
}