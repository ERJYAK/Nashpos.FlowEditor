@page "/editor"
@inherits FluxorComponent
@implements IDisposable

<MudAppBar Elevation="1" Dense="true">
    <MudText Typo="Typo.h6" Class="mr-4">Workflow Editor</MudText>

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="CreateNewWorkflow">
        Создать процесс
    </MudButton>

    <MudMenu Label="Добавить шаг"
             Variant="Variant.Filled"
             Color="Color.Secondary"
             Class="ml-2"
             StartIcon="@Icons.Material.Filled.AddBox"
             EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
             Disabled="@(State.Value.ActiveDocumentName is null)">
        <MudMenuItem OnClick="AddBaseStep">Базовый шаг</MudMenuItem>
        <MudMenuItem OnClick="AddSubflowStep">Шаг subflow</MudMenuItem>
        <MudMenuItem OnClick="AddJsScriptStep">JS-шаг (execute-js-script)</MudMenuItem>
    </MudMenu>

    <MudMenu Label="Файл"
             Variant="Variant.Filled"
             Color="Color.Tertiary"
             Class="ml-2"
             StartIcon="@Icons.Material.Filled.Folder"
             EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
        <MudMenuItem OnClick="OpenFilePicker">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.UploadFile" Size="Size.Small" />
                <span>Загрузить файл</span>
            </MudStack>
        </MudMenuItem>
        <MudMenuItem OnClick="SaveActiveAsFile" Disabled="@(State.Value.ActiveDocumentName is null)">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Save" Size="Size.Small" />
                <span>Сохранить файл</span>
            </MudStack>
        </MudMenuItem>
        <MudMenuItem OnClick="SaveActiveToServer" Disabled="@(State.Value.ActiveDocumentName is null)">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Small" />
                <span>Сохранить на сервер</span>
            </MudStack>
        </MudMenuItem>
    </MudMenu>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.Close"
               Class="ml-2"
               Disabled="@(State.Value.ActiveDocumentName is null)"
               OnClick="CloseActiveTab">
        Закрыть вкладку
    </MudButton>

    <MudIconButton Icon="@Icons.Material.Filled.Undo"
                   Color="Color.Inherit"
                   Class="ml-2"
                   Disabled="@(!CanUndoActive())"
                   OnClick="UndoActive"
                   title="Отменить (Ctrl+Z)" />
    <MudIconButton Icon="@Icons.Material.Filled.Redo"
                   Color="Color.Inherit"
                   Disabled="@(!CanRedoActive())"
                   OnClick="RedoActive"
                   title="Повторить (Ctrl+Y / Ctrl+Shift+Z)" />

    <MudSpacer />
</MudAppBar>

@* MudFileUpload — невидимый, открывается из меню «Файл» через _fileUpload?.OpenFilePickerAsync().
   Внешняя обёртка `display:none` — единственный надёжный способ, не зависящий от внутренней
   реализации MudFileUpload (атрибут Hidden=true в 9.x иногда оставляет видимый «Browse files»). *@
<div style="display: none; position: absolute;">
    <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                   @ref="_fileUpload"
                   Accept=".json"
                   FilesChanged="OnFilesPicked" />
</div>

<div id="editor-drop-zone"
     class="editor-container"
     style="height: calc(100vh - 64px);"
     @oncontextmenu="ShowContextMenu"
     @oncontextmenu:preventDefault="true">

    @if (State.Value.OpenDocuments.Count > 0)
    {
        <div id="workflow-tabs-container" class="workflow-tabs">
            @foreach (var name in OrderedTabNames())
            {
                var localName = name; // capture for click handler
                var isActive = name == State.Value.ActiveDocumentName;
                <div class="@TabClass(name, isActive)"
                     draggable="true"
                     data-tab-name="@name"
                     @onclick="() => Dispatcher.Dispatch(new SwitchTabAction(localName))"
                     @ondblclick="() => StartEditTab(localName)"
                     @ondblclick:stopPropagation="true">
                    @if (_editingTabName == name)
                    {
                        <input class="tab-name-input"
                               value="@_editTabValue"
                               @oninput="e => _editTabValue = (string)(e.Value ?? string.Empty)"
                               @onblur="CommitEditTab"
                               @onkeydown="EditTabKeyDown"
                               @onkeydown:stopPropagation="true"
                               @ref="_editingTabInput" />
                    }
                    else
                    {
                        @if (State.Value.IsDirty(name))
                        {
                            <span class="dirty-mark">●</span>
                        }
                        <span>@name</span>
                        <span @onclick:stopPropagation="true" @ondblclick:stopPropagation="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Size="Size.Small"
                                           Color="@(isActive ? Color.Inherit : Color.Default)"
                                           OnClick="@(() => CloseTab(localName))"
                                           title="Закрыть вкладку" />
                        </span>
                    }
                </div>
            }
        </div>

        @if (State.Value.ActiveDocumentName is { } activeName &&
             State.Value.OpenDocuments.ContainsKey(activeName))
        {
            <div style="height: calc(100vh - 120px);">
                @* @key пересоздаёт CanvasTab при смене активной вкладки — иначе старые узлы
                   из предыдущего документа остаются в Diagram и «перетекают» на новый холст. *@
                <CanvasTab @key="@activeName"
                           @ref="_activeCanvas"
                           Name="@activeName"
                           OnSelectionChanged="@(s => _selection = s)"
                           OnContextMenuRequested="@(info => _contextMenuInfo = info)"/>
            </div>
        }
    }
</div>

<EditorContextMenu @ref="_contextMenu" />

@code {
    [Inject] private IState<EditorState> State { get; set; } = null!;
    [Inject] private IDispatcher Dispatcher { get; set; } = null!;
    [Inject] private IJSRuntime JS { get; set; } = null!;
    [Inject] private IDialogService Dialogs { get; set; } = null!;
    [Inject] private IFileDownloader Downloader { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private const string DraftPrefix = "new-workflow-";

    private EditorContextMenu _contextMenu = null!;
    private CanvasTab? _activeCanvas;
    private IReadOnlyList<SelectableModel> _selection = Array.Empty<SelectableModel>();
    private (IReadOnlyList<SelectableModel> Selection, double CanvasX, double CanvasY)? _contextMenuInfo;

    private DotNetObjectReference<Editor>? _selfRef;
    private bool _dropZoneAttached;
    private bool _tabReorderAttached;
    private MudFileUpload<IReadOnlyList<IBrowserFile>>? _fileUpload;

    private string? _editingTabName;
    private string _editTabValue = string.Empty;
    private ElementReference _editingTabInput;
    private bool _focusEditingTab;

    private Task OpenFilePicker() => _fileUpload?.OpenFilePickerAsync() ?? Task.CompletedTask;

    private IEnumerable<string> OrderedTabNames()
    {
        // TabOrder может содержать удалённые имена (paranoia) или забытые — фильтруем + дописываем хвост.
        var seen = new HashSet<string>();
        foreach (var n in State.Value.TabOrder)
        {
            if (State.Value.OpenDocuments.ContainsKey(n) && seen.Add(n)) yield return n;
        }
        foreach (var n in State.Value.OpenDocuments.Keys)
        {
            if (seen.Add(n)) yield return n;
        }
    }

    private string TabClass(string name, bool isActive)
    {
        var classes = new List<string> { "workflow-tab" };
        if (isActive) classes.Add("active");
        return string.Join(' ', classes);
    }

    private void StartEditTab(string name)
    {
        _editingTabName = name;
        _editTabValue = name;
        _focusEditingTab = true;
    }

    private void EditTabKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") CommitEditTab();
        else if (e.Key == "Escape") CancelEditTab();
    }

    private void CancelEditTab()
    {
        _editingTabName = null;
        _editTabValue = string.Empty;
    }

    private void CommitEditTab()
    {
        var oldName = _editingTabName;
        var newName = _editTabValue.Trim();
        _editingTabName = null;
        _editTabValue = string.Empty;
        if (oldName is null || string.IsNullOrEmpty(newName) || newName == oldName) return;

        Dispatcher.Dispatch(new RenameWorkflowRequestedAction(oldName, newName, CascadeSubflows: true));
    }

    [JSInvokable]
    public Task OnTabsReordered(string[] order)
    {
        Dispatcher.Dispatch(new ReorderTabsAction(order));
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (firstRender)
        {
            _selfRef ??= DotNetObjectReference.Create(this);

            if (!_dropZoneAttached)
            {
                await JS.InvokeVoidAsync("fileDrop.attach", "editor-drop-zone", _selfRef);
                _dropZoneAttached = true;
            }

            // Авто-создание пустого холста при первом заходе на /editor.
            if (State.Value.OpenDocuments.Count == 0)
            {
                Dispatcher.Dispatch(new CreateWorkflowRequestedAction(GenerateDraftName()));
            }
        }

        // Tab-reorder JS привязывается к контейнеру вкладок, который появляется только когда есть документы.
        if (!_tabReorderAttached && State.Value.OpenDocuments.Count > 0)
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("tabReorder.attach", "workflow-tabs-container", _selfRef);
            _tabReorderAttached = true;
        }

        if (_focusEditingTab && _editingTabName is not null)
        {
            _focusEditingTab = false;
            try { await _editingTabInput.FocusAsync(); } catch { /* ok */ }
        }
    }

    private string GenerateDraftName()
    {
        for (var i = 1; ; i++)
        {
            var candidate = DraftPrefix + i;
            if (!State.Value.OpenDocuments.ContainsKey(candidate)) return candidate;
        }
    }

    [JSInvokable]
    public Task OnBatchStart(int count)
    {
        Dispatcher.Dispatch(new BatchImportStartedAction(count));
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnFileDropped(string name, string text)
    {
        Dispatcher.Dispatch(new ImportFileRequestedAction(name, text));
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnFileDropFailed(string name, string error)
    {
        Snackbar.Add($"Не удалось прочитать файл «{name}»: {error}", Severity.Error);
        Dispatcher.Dispatch(new ImportFileFailedAction(name, error));
        return Task.CompletedTask;
    }

    private async Task OnFilesPicked(IReadOnlyList<IBrowserFile>? files)
    {
        if (files is null || files.Count == 0) return;
        Dispatcher.Dispatch(new BatchImportStartedAction(files.Count));
        foreach (var file in files)
        {
            try
            {
                await using var stream = file.OpenReadStream(maxAllowedSize: 4 * 1024 * 1024);
                using var reader = new StreamReader(stream);
                var text = await reader.ReadToEndAsync();
                Dispatcher.Dispatch(new ImportFileRequestedAction(file.Name, text));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Не удалось прочитать файл «{file.Name}»: {ex.Message}", Severity.Error);
                Dispatcher.Dispatch(new ImportFileFailedAction(file.Name, ex.Message));
            }
        }
    }

    private void ShowContextMenu(MouseEventArgs e)
    {
        var target = _contextMenuInfo?.Selection ?? _selection;
        var canvasX = _contextMenuInfo?.CanvasX ?? 0;
        var canvasY = _contextMenuInfo?.CanvasY ?? 0;
        _contextMenu.Open(e.ClientX, e.ClientY, target, canvasX, canvasY);
        _contextMenuInfo = null;
    }

    private int GetActiveIndex()
    {
        if (State.Value.ActiveDocumentName is null) return 0;
        var names = State.Value.OpenDocuments.Keys.OrderBy(k => k).ToList();
        var index = names.IndexOf(State.Value.ActiveDocumentName);
        return index >= 0 ? index : 0;
    }

    private void OnTabChanged(int index)
    {
        var names = State.Value.OpenDocuments.Keys.OrderBy(k => k).ToList();
        if (index >= 0 && index < names.Count)
            Dispatcher.Dispatch(new SwitchTabAction(names[index]));
    }

    private async Task SaveActiveAsFile()
    {
        var name = State.Value.ActiveDocumentName;
        if (name is null) return;
        if (!State.Value.OpenDocuments.TryGetValue(name, out var editor)) return;

        var validation = WorkflowGraphValidator.ValidateForExport(editor.Document.Steps, editor.Links);
        if (!validation.IsValid)
        {
            Dispatcher.Dispatch(new MarkInvalidStepsAction(name, validation.InvalidStepIds.ToList()));
            Snackbar.Add($"Не удалось сохранить: {validation.Message}", Severity.Error);
            return;
        }

        Dispatcher.Dispatch(new ClearInvalidStepsAction(name));
        var json = System.Text.Json.JsonSerializer.Serialize(editor.Document, JsonConfiguration.GetOptions());
        await Downloader.DownloadAsync($"{name}.json", json);
    }

    private void SaveActiveToServer()
    {
        var name = State.Value.ActiveDocumentName;
        if (name is not null) Dispatcher.Dispatch(new SaveWorkflowAction(name));
    }

    private async Task CreateNewWorkflow()
    {
        var parameters = new DialogParameters
        {
            { nameof(NameDialog.Title), "Новый процесс" },
            { nameof(NameDialog.Label), "Имя процесса" },
            { nameof(NameDialog.SubmitLabel), "Создать" },
            { nameof(NameDialog.AdditionalValidator),
              (Func<string, string?>)(s =>
                  State.Value.OpenDocuments.ContainsKey(s) ? "Процесс с таким именем уже открыт" : null) }
        };
        var dialog = await Dialogs.ShowAsync<NameDialog>("Новый процесс", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var name = (string)result.Data!;
        Dispatcher.Dispatch(new CreateWorkflowRequestedAction(name));
    }

    private async Task AddBaseStep()
    {
        var docName = State.Value.ActiveDocumentName;
        if (docName is null) return;

        var step = new BaseStep { Id = Guid.NewGuid().ToString(), Description = "Новый шаг" };
        Dispatcher.Dispatch(new AddStepAction(docName, step, NextAddPosition()));
        await Task.CompletedTask;
    }

    private async Task AddJsScriptStep()
    {
        var docName = State.Value.ActiveDocumentName;
        if (docName is null) return;

        var step = new BaseStep
        {
            Id = Guid.NewGuid().ToString(),
            StepKind = JsScriptNodeModel.ConstStepKind,
            Description = "Новый JS-шаг"
        };
        Dispatcher.Dispatch(new AddStepAction(docName, step, NextAddPosition()));
        await Task.CompletedTask;
    }

    private async Task AddSubflowStep()
    {
        var docName = State.Value.ActiveDocumentName;
        if (docName is null) return;

        var parameters = new DialogParameters
        {
            { nameof(NameDialog.Title), "Новый subflow-шаг" },
            { nameof(NameDialog.Label), "Имя подпроцесса" },
            { nameof(NameDialog.SubmitLabel), "Добавить" }
        };
        var dialog = await Dialogs.ShowAsync<NameDialog>("Новый subflow-шаг", parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var subflowName = (string)result.Data!;
        var step = new SubflowStep
        {
            Id = Guid.NewGuid().ToString(),
            SubflowName = subflowName,
            Description = string.Empty
        };
        Dispatcher.Dispatch(new AddStepAction(docName, step, NextAddPosition()));
    }

    private CanvasPosition NextAddPosition()
    {
        var center = _activeCanvas?.GetViewportCenter();
        return center.HasValue
            ? new CanvasPosition(center.Value.X, center.Value.Y)
            : new CanvasPosition(100, 100);
    }

    private async Task CloseTab(string name)
    {
        if (State.Value.IsDirty(name))
        {
            var ok = await JS.InvokeAsync<bool>(
                "confirm",
                "В этом процессе есть несохранённые изменения. Закрыть без сохранения?");
            if (!ok) return;
        }
        Dispatcher.Dispatch(new CloseTabAction(name));
    }

    private Task CloseActiveTab()
    {
        var name = State.Value.ActiveDocumentName;
        return name is null ? Task.CompletedTask : CloseTab(name);
    }

    private bool CanUndoActive() =>
        State.Value.ActiveDocumentName is not null && State.Value.CanUndo(State.Value.ActiveDocumentName);

    private bool CanRedoActive() =>
        State.Value.ActiveDocumentName is not null && State.Value.CanRedo(State.Value.ActiveDocumentName);

    private void UndoActive()
    {
        var name = State.Value.ActiveDocumentName;
        if (name is not null) Dispatcher.Dispatch(new UndoAction(name));
    }

    private void RedoActive()
    {
        var name = State.Value.ActiveDocumentName;
        if (name is not null) Dispatcher.Dispatch(new RedoAction(name));
    }

    void IDisposable.Dispose()
    {
        if (_dropZoneAttached)
            _ = JS.InvokeVoidAsync("fileDrop.detach", "editor-drop-zone");
        if (_tabReorderAttached)
            _ = JS.InvokeVoidAsync("tabReorder.detach", "workflow-tabs-container");
        _selfRef?.Dispose();
    }
}
