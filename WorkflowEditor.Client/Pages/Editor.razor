@page "/editor"
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@using Fluxor
@using MudBlazor
@using WorkflowEditor.Client.Store.Editor
@using WorkflowEditor.Client.Components

<MudAppBar Elevation="1" Dense="true">
    <MudText Typo="Typo.h6" Class="mr-4">Workflow Editor</MudText>
    <MudButton Variant="Variant.Filled" 
               Color="Color.Primary" 
               StartIcon="@Icons.Material.Filled.Save"
               OnClick="SaveActiveDocument">
        Сохранить
    </MudButton>
    
    <MudButton Variant="Variant.Filled" 
               Color="Color.Secondary" 
               OnClick="CreateTestWorkflow">
        Тестовый узел
    </MudButton>
    
    <MudSpacer />
</MudAppBar>

<div class="editor-container mt-2" style="height: calc(100vh - 64px);">
    @if (State.Value.OpenDocuments.Any())
    {
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-0" 
                 ActivePanelIndexChanged="OnTabChanged">
            @foreach (var doc in State.Value.OpenDocuments.Values)
            {
                <MudTabPanel Text="@doc.Name" Tag="@doc.WorkflowId">
                    <div style="height: calc(100vh - 120px);">
                        <CanvasTab WorkflowId="@doc.WorkflowId" />
                    </div>
                </MudTabPanel>
            }
        </MudTabs>
    }
    else
    {
        <MudAlert Severity="Severity.Info">Нет открытых процессов</MudAlert>
    }
</div>

@code {
    [Inject] private IState<EditorState> State { get; set; } = null!;
    [Inject] private IDispatcher Dispatcher { get; set; } = null!;

    protected override void OnInitialized()
    {
        base.OnInitialized();
    
        // Загружаем основной рабочий процесс при входе в редактор
        // В реальном приложении ID может приходить из URL или списка файлов
        Dispatcher.Dispatch(new LoadWorkflowAction("main-flow-id"));
    }
    
    private void OnTabChanged(int index)
    {
        // При переключении вкладок обновляем ActiveDocumentId в стейте
        var workflowId = State.Value.OpenDocuments.Values.ElementAt(index).WorkflowId;
        Dispatcher.Dispatch(new SwitchTabAction(workflowId));
    }

    private void SaveActiveDocument()
    {
        if (State.Value.ActiveDocumentId != null)
        {
            // Триггерим эффект сохранения через gRPC
            Dispatcher.Dispatch(new SaveWorkflowAction(State.Value.ActiveDocumentId));
        }
    }
    
    private void CreateTestWorkflow()
    {
        var testDoc = new WorkflowEditor.Core.Models.WorkflowDocument
        {
            WorkflowId = "test-id",
            Name = "Тестовый процесс",
            Steps = new List<WorkflowEditor.Core.Models.WorkflowStep>
            {
                new WorkflowEditor.Core.Models.Steps.SubflowStep
                {
                    Id = "node-1",
                    Name = "Ручная проверка",
                    SubflowId = "manual-check-01",
                    Position = new WorkflowEditor.Core.Models.CanvasPosition(50, 50)
                }
            }
        };
    
        Dispatcher.Dispatch(new LoadWorkflowSuccessAction(testDoc));
    }
}