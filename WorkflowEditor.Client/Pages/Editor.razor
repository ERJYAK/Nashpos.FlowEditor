@page "/editor"
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@using Fluxor
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using WorkflowEditor.Client.Store.Editor
@using WorkflowEditor.Client.Components
@using WorkflowEditor.Core.Models
@using WorkflowEditor.Core.Models.Steps
@using Blazor.Diagrams.Core.Models.Base

<MudAppBar Elevation="1" Dense="true">
    <MudText Typo="Typo.h6" Class="mr-4">Workflow Editor</MudText>
    
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="CreateNewWorkflow">
         Создать процесс
    </MudButton>

    <MudButton Variant="Variant.Filled" 
               Color="Color.Secondary" 
               Class="ml-2"
               StartIcon="@Icons.Material.Filled.AddBox"
               Disabled="@(State.Value.ActiveDocumentId == null)"
               OnClick="AddStepToActive">
        Добавить шаг
    </MudButton>
    
    <MudSpacer />
</MudAppBar>

<div class="editor-container mt-2" style="height: calc(100vh - 64px);"
     @oncontextmenu="ShowContextMenu"
     @oncontextmenu:preventDefault="true">
    
    @if (State.Value.OpenDocuments.Any())
    {
        @* Привязываем ActivePanelIndex к нашему стейту через поиск индекса *@
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true"
                 ActivePanelIndex="@GetActiveIndex()"
                 ActivePanelIndexChanged="OnTabChanged">

            @* Добавляем OrderBy прямо в разметку *@
            @foreach (var doc in State.Value.OpenDocuments.Values.OrderBy(d => d.CreatedAt))
            {
                <MudTabPanel Text="@doc.Name" Tag="@doc.WorkflowId">

                    @* КРИТИЧЕСКИЙ ФИКС: Рендерим холст ТОЛЬКО для активной вкладки *@
                    @if (State.Value.ActiveDocumentId == doc.WorkflowId)
                    {
                        <div style="height: calc(100vh - 120px);">
                            <CanvasTab @ref="_activeCanvas"
                                       WorkflowId="@doc.WorkflowId"
                                       OnSelectionChanged="@(s => _selection = s)"
                                       OnContextMenuRequested="@(info => _contextMenuInfo = info)"/>
                        </div>
                    }

                </MudTabPanel>
            }
        </MudTabs>
    }
    else
    {
        <MudStack AlignItems="AlignItems.Center" Class="mt-10">
            <MudAlert Severity="Severity.Info">Нет открытых процессов. Создайте новый, чтобы начать работу.</MudAlert>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="CreateNewWorkflow">
                Создать первый процесс
            </MudButton>
        </MudStack>
    }
</div>

<EditorContextMenu @ref="_contextMenu" />

@code {
    [Inject] private IState<EditorState> State { get; set; } = null!;
    [Inject] private IDispatcher Dispatcher { get; set; } = null!;
    
    private EditorContextMenu _contextMenu = null!;
    private CanvasTab? _activeCanvas;
    private IReadOnlyList<SelectableModel> _selection = Array.Empty<SelectableModel>();
    private (IReadOnlyList<SelectableModel> Selection, double CanvasX, double CanvasY)? _contextMenuInfo;

    private void ShowContextMenu(MouseEventArgs e)
    {
        var target = _contextMenuInfo?.Selection ?? _selection;
        var canvasX = _contextMenuInfo?.CanvasX ?? 0;
        var canvasY = _contextMenuInfo?.CanvasY ?? 0;
        _contextMenu.Open(e.ClientX, e.ClientY, target, canvasX, canvasY);
        _contextMenuInfo = null;
    }
    
    private int GetActiveIndex()
    {
        if (State.Value.ActiveDocumentId == null) return 0;
        
        // Строгая сортировка по времени создания
        var list = State.Value.OpenDocuments.Values.OrderBy(d => d.CreatedAt).ToList();
        var index = list.FindIndex(d => d.WorkflowId == State.Value.ActiveDocumentId);
        
        return index >= 0 ? index : 0;
    }

    private void OnTabChanged(int index)
    {
        // Синхронизируем массив для правильного переключения
        var docs = State.Value.OpenDocuments.Values.OrderBy(d => d.CreatedAt).ToList();
        if (index >= 0 && index < docs.Count)
        {
            Dispatcher.Dispatch(new SwitchTabAction(docs[index].WorkflowId));
        }
    }

    private void SaveActiveDocument()
    {
        if (State.Value.ActiveDocumentId != null)
        {
            Dispatcher.Dispatch(new SaveWorkflowAction(State.Value.ActiveDocumentId));
        }
    }
    
    private void AddStepToActive()
    {
        var activeId = State.Value.ActiveDocumentId;
        if (activeId == null) return;

        var offset = new Random().Next(0, 50);
        var center = _activeCanvas?.GetViewportCenter();
        var pos = center.HasValue
            ? new CanvasPosition(center.Value.X + offset, center.Value.Y + offset)
            : new CanvasPosition(100 + offset, 100 + offset);

        Dispatcher.Dispatch(new AddStepAction(activeId, new BaseStep
        {
            Id = Guid.NewGuid().ToString(),
            Name = "Новая задача",
            Position = pos
        }));
    }
    
    private void CreateNewWorkflow()
    {
        Console.WriteLine("[Слой UI] Нажата кнопка 'Создать процесс'. Отправляем экшен...");
        Dispatcher.Dispatch(new CreateNewWorkflowAction());
    }
}